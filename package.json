{
  "name": "smart_car_parking",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@react-google-maps/api": "^2.20.8",
    "@tanstack/react-query": "^5.62.9",
    "@tanstack/react-table": "^8.20.5",
    "@testing-library/jest-dom": "^5.16.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "lucide-react": "^1.8.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.30.3",
    "react-scripts": "^5.0.1",
    "recharts": "^2.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.23.8"
  },
  "overrides": {
    "@tootallnate/once": "3.0.1",
    "nth-check": "2.1.1",
    "serialize-javascript": "7.0.5",
    "underscore": "1.13.8",
    "webpack-dev-server": "4.15.2",
    "resolve-url-loader": {
      "postcss": "8.5.10"
    }
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "eject": "react-scripts eject",
    "migrate:parking-slots": "node scripts/migrateParkingSlotsToCanonical.js",
    "firebase:emulators": "npx -y firebase-tools@latest emulators:start --project digital-parking-f9d2c --only functions",
    "firebase:emulators:all": "npx -y firebase-tools@latest emulators:start --project digital-parking-f9d2c --only firestore,functions",
    "deploy:firestore": "npx -y firebase-tools@latest deploy --project digital-parking-f9d2c --only firestore:rules,firestore:indexes",
    "deploy:functions": "npx -y firebase-tools@latest deploy --project digital-parking-f9d2c --only functions",
    "deploy:phase2": "npm run deploy:firestore && npm run deploy:functions"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.14"
  }
}
