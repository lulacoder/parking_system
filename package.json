{
  "name": "smart_car_parking",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@react-google-maps/api": "^2.20.8",
    "@testing-library/jest-dom": "^5.16.3",
    "@testing-library/react": "^12.1.4",
    "@testing-library/user-event": "^13.5.0",
    "bootstrap": "^5.3.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^9.23.0",
    "firebase-admin": "^13.5.0",
    "lucide-react": "^1.8.0",
    "mdbreact": "^5.2.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "6.30.1",
    "react-scripts": "5.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "migrate:parking-slots": "node scripts/migrateParkingSlotsToCanonical.js",
    "firebase:emulators": "npx -y firebase-tools@latest emulators:start --project digital-parking-f9d2c --only functions",
    "firebase:emulators:all": "npx -y firebase-tools@latest emulators:start --project digital-parking-f9d2c --only firestore,functions",
    "deploy:firestore": "npx -y firebase-tools@latest deploy --project digital-parking-f9d2c --only firestore:rules,firestore:indexes",
    "deploy:functions": "npx -y firebase-tools@latest deploy --project digital-parking-f9d2c --only functions",
    "deploy:phase2": "npm run deploy:firestore && npm run deploy:functions"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.14"
  }
}
